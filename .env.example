# Neon Postgres connection string (de Neon → Connection Details)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Secret para encriptar la cookie de sesión (mínimo 32 caracteres)
# Genera con: openssl rand -base64 48
SESSION_SECRET=cambia-esto-por-un-string-aleatorio-de-al-menos-32-chars
